{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@vm/shared-types": [
        "packages/shared-types/src"
      ],
      "@vm/shared-client": [
        "packages/shared-client/src"
      ],
      "@vm/shared-client/*": [
        "packages/shared-client/src/*"
      ]
    }
  }
}
