# 本地浏览器 / H5 / App 联调：
VITE_API_BASE_URL=http://127.0.0.1:4000/api

# 微信开发者工具里如果开启了“不校验合法域名...”，也可以临时改成局域网 IP，例如：
# VITE_API_BASE_URL=http://192.168.1.20:4000/api

# 微信小程序真机和正式环境不能直接使用 http 或 IP。
# 这时必须改成已经在微信公众平台“服务器域名”里配置好的 https 域名，例如：
# VITE_API_BASE_URL=http://203.0.113.10:4000/api
# VITE_API_BASE_URL=https://api.example.com/api
