# 服务基础配置
PORT=4000
PUBLIC_BASE_URL=http://127.0.0.1:4000
API_DATA_FILE=runtime-data/store.json
UPLOAD_DIR=runtime-uploads
SYSTEM_LOG_FILE=runtime-data/system-audit.ndjson
BUSINESS_TIMEZONE_OFFSET_HOURS=8
BUSINESS_DAY_START_HOUR=4

# 地图服务
AMAP_WEB_KEY=

# 柜机平台接入
SMARTVM_BASE_URL=http://pre.smartvm.cn
SMARTVM_CLIENT_ID=
SMARTVM_KEY=
SMARTVM_DEFAULT_PAY_STYLE=2
SMARTVM_TEST_DEVICE_CODE=91120149
SMARTVM_TEST_DOOR_NUM=1
SMARTVM_DOOR_STATUS_CALLBACK_PATH=/api/cabinet-events/callbacks/door-status
SMARTVM_SETTLEMENT_CALLBACK_PATH=/api/cabinet-events/callbacks/settlement
SMARTVM_ADJUSTMENT_CALLBACK_PATH=/api/cabinet-events/callbacks/adjustment
SMARTVM_REFUND_CALLBACK_PATH=/api/inventory-orders/callbacks/refund
SMARTVM_PAYMENT_SUCCESS_PATH=/api/pay/container/paymentSuccess

# 阿里云短信
VERIFICATION_CODE_PROVIDER=mock
VERIFICATION_CODE_PREVIEW_ENABLED=true
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_REGION_ID=cn-hangzhou
ALIYUN_SMS_ENDPOINT=dysmsapi.aliyuncs.com
