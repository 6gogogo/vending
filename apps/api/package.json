{
  "name": "@vm/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "data:init": "tsx src/scripts/init-data.ts",
    "data:init:empty": "tsx src/scripts/init-empty-data.ts",
    "db:generate": "prisma generate --config prisma.config.ts",
    "db:push": "prisma db push --config prisma.config.ts",
    "db:migrate": "prisma migrate dev --config prisma.config.ts",
    "db:migrate-json": "tsx src/scripts/migrate-json-to-postgres.ts",
    "start:once": "tsx src/main.ts",
    "start:dev": "tsx watch src/main.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@alicloud/dysmsapi20170525": "^4.5.1",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.1.17",
    "@prisma/client": "^7.8.0",
    "@vm/shared-client": "file:../../packages/shared-client",
    "@vm/shared-types": "file:../../packages/shared-types",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "prisma": "^7.8.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
